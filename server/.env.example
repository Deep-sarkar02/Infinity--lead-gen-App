PORT=3001

# MongoDB Atlas
# 1. Create a free cluster at https://cloud.mongodb.com
# 2. Database Access → create user with read/write on infinity_runner
# 3. Network Access → add your IP (or 0.0.0.0/0 for dev)
# 4. Connect → Drivers → copy connection string, set database to infinity_runner
# URL-encode special characters in the password (@ → %40, $ → %24, etc.)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/infinity_runner?retryWrites=true&w=majority

# Gupshup WhatsApp — POST /wa/api/v1/template/msg
GUPSHUP_API_KEY=your_api_key_here
GUPSHUP_SOURCE=919355586891
GUPSHUP_APP_NAME=PuMkzIVgOU868jw9it7u3ovd
GUPSHUP_TEMPLATE_ID=53e0fc5d-4c4a-4096-bb4d-83dc8a03201d

# Gupshup SMS — GET enterprise gateway (OTP on lead add)
GUPSHUP_SMS_USERID=your_userid_here
GUPSHUP_SMS_PASSWORD=your_password_here
GUPSHUP_SMS_URL=https://enterprise.smsgupshup.com/GatewayAPI/rest
