# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
TRUST_PROXY=true

# Comma-separated origins if the API is called cross-origin (optional with Docker/nginx same-host)
# ALLOWED_ORIGINS=https://your-domain.com

# Docker published port for the frontend container (host → container :80)
APP_PORT=80

# ── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas — URL-encode special characters in the password (@ → %40, $ → %24)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/infinity_runner?retryWrites=true&w=majority

# ── Gupshup WhatsApp ─────────────────────────────────────────────────────────
GUPSHUP_API_KEY=your_api_key_here
GUPSHUP_SOURCE=919355586891
GUPSHUP_APP_NAME=PuMkzIVgOU868jw9it7u3ovd
GUPSHUP_TEMPLATE_ID=53e0fc5d-4c4a-4096-bb4d-83dc8a03201d

GUPSHUP_OTP_API_KEY=your_otp_api_key_here
GUPSHUP_OTP_SOURCE=919100074637
GUPSHUP_OTP_APP_NAME=Ir3XLFWEurt0MjswxkLsDWM5
GUPSHUP_OTP_TEMPLATE_ID=51109c78-288e-45ac-a4bb-b1b5e62eadc3

GUPSHUP_SMS_USERID=your_userid_here
GUPSHUP_SMS_PASSWORD=your_password_here
GUPSHUP_SMS_URL=https://enterprise.smsgupshup.com/GatewayAPI/rest

# Gupshup inbound webhook — same value in callback URL ?secret=
GUPSHUP_WEBHOOK_SECRET=change-me-for-production

# ── Frontend (Vite build) ────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Leave empty — frontend nginx proxies /api to backend (Docker)
VITE_API_URL=
